VITE_API_BASE_URL=https://app.steadyrise.us/api
# Absolute API URL used by Capacitor (iOS/Android) builds. The web build
# uses VITE_API_BASE_URL above. Required when building for native.
VITE_API_BASE_URL_NATIVE=https://family-budget-api.example.run.app/api
VITE_FIREBASE_API_KEY=key-value
VITE_FIREBASE_AUTH_DOMAIN=auth-domain.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=project-id
