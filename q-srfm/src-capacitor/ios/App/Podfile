require_relative '../../node_modules/@capacitor/ios/scripts/pods_helpers'

platform :ios, '15.0'
# `:linkage => :static` is required because @capacitor-firebase/authentication's
# podspec sets `static_framework = true`. With a bare `use_frameworks!` (dynamic
# linkage), CocoaPods creates no Pods.xcodeproj target for that pod, so its
# Swift sources never compile and the App target never links against it —
# manifesting at runtime as `"FirebaseAuthentication" plugin is not implemented
# on ios`. Static linkage is also Firebase iOS SDK's recommended setup.
use_frameworks! :linkage => :static

# workaround to avoid Xcode caching of Pods that requires
# Product -> Clean Build Folder after new Cordova plugins installed
# Requires CocoaPods 1.6 or newer
install! 'cocoapods', :disable_input_output_paths => true

def capacitor_pods
  pod 'Capacitor', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorCordova', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorFirebaseAuthentication', :path => '../../node_modules/@capacitor-firebase/authentication'
  pod 'CapacitorApp', :path => '../../node_modules/@capacitor/app'
end

target 'App' do
  capacitor_pods
  # GoogleSignIn is the dependency declared by the plugin's `Google`
  # subspec, but the source-injection workaround below bypasses the
  # subspec — so we declare it directly to keep `import GoogleSignIn`
  # resolvable from the injected plugin sources. We use ~> 9.1 rather
  # than the plugin's pinned 9.0.0 because 9.0.0 requires
  # GTMSessionFetcher/Core ~> 3.3, which conflicts with FirebaseAuth
  # 12.7.0's `>= 3.4, < 6.0` constraint.
  pod 'GoogleSignIn', '~> 9.1'
end

post_install do |installer|
  assertDeploymentTarget(installer)

  app_target = installer.aggregate_targets.find { |t| t.name == 'Pods-App' }&.user_targets&.first
  raise "post_install: could not locate App target" if app_target.nil?
  project = app_target.project

  # ---- Clean up the Cap-7-era source-injection workaround ----
  # A previous Podfile (when the CapacitorFirebaseAuthentication pod
  # target was generating as an empty aggregate target under
  # CocoaPods 1.16 + the Google subspec) injected the plugin's
  # `.swift`/`.m` files directly into the App target. Under Cap 8
  # the pod target compiles correctly on its own, so leaving the
  # injected references in place produces duplicate-symbol linker
  # errors (e.g. `_OBJC_CLASS_$_FirebaseAuthenticationPlugin`).
  # Remove the injected group and any matching build-file references.
  legacy_group = project.main_group.find_subpath('CapacitorFirebaseAuthentication-Sources', false)
  if legacy_group
    legacy_paths = legacy_group.recursive_children_groups.flat_map(&:files) + legacy_group.files
    legacy_real_paths = legacy_paths.map { |f| f.real_path.to_s }
    [app_target.source_build_phase, app_target.resources_build_phase].each do |phase|
      phase.files.dup.each do |bf|
        next unless bf.file_ref && legacy_real_paths.include?(bf.file_ref.real_path.to_s)
        phase.remove_build_file(bf)
      end
    end
    legacy_group.recursive_children_groups.each(&:remove_from_project)
    legacy_group.files.each(&:remove_from_project)
    legacy_group.remove_from_project
  end

  # ---- Remove `-DRGCFA_INCLUDE_GOOGLE` from the App target ----
  # The flag belongs on the plugin's own pod target (set below), not
  # on the App target. Leaving it here is harmless but misleading.
  app_target.build_configurations.each do |config|
    flags = config.build_settings['OTHER_SWIFT_FLAGS']
    next unless flags
    cleaned = Array(flags).flat_map { |f| f.to_s.split(' ') }.reject { |tok| tok == '-DRGCFA_INCLUDE_GOOGLE' }.join(' ')
    config.build_settings['OTHER_SWIFT_FLAGS'] = cleaned
  end

  # ---- Apply Google-handler compile flag to the plugin pod ----
  # The plugin's source code wraps GoogleSignIn-using paths in
  # `#if RGCFA_INCLUDE_GOOGLE`. That flag is normally set by the
  # plugin's `Google` subspec, but we cannot request that subspec
  # because it pins GoogleSignIn 9.0.0 — which conflicts with
  # FirebaseAuth 12.7.0's GTMSessionFetcher constraint. So we
  # declare GoogleSignIn ourselves (target line above) and stamp
  # the compile flag onto the plugin's pod target here.
  installer.pods_project.targets.each do |t|
    next unless t.name == 'CapacitorFirebaseAuthentication'
    t.build_configurations.each do |config|
      flags = config.build_settings['OTHER_SWIFT_FLAGS'] || '$(inherited)'
      flags = Array(flags).join(' ')
      unless flags.include?('-DRGCFA_INCLUDE_GOOGLE')
        config.build_settings['OTHER_SWIFT_FLAGS'] = "#{flags} -DRGCFA_INCLUDE_GOOGLE"
      end

      # The plugin's umbrella podspec does not list GoogleSignIn as
      # a dependency (only its Google subspec does), so the pod's
      # target does not see the GoogleSignIn framework headers.
      # Inject the search path so `import GoogleSignIn` resolves.
      # GoogleSignIn is brought in as a real pod via the explicit
      # `pod 'GoogleSignIn'` line in the target above.
      gsi_search = '"${PODS_CONFIGURATION_BUILD_DIR}/GoogleSignIn"'
      ['FRAMEWORK_SEARCH_PATHS', 'SWIFT_INCLUDE_PATHS'].each do |key|
        existing = config.build_settings[key] || '$(inherited)'
        existing = Array(existing).join(' ')
        unless existing.include?('GoogleSignIn')
          config.build_settings[key] = "#{existing} #{gsi_search}"
        end
      end
    end
  end

  # ---- Bundle GoogleService-Info.plist ----
  # Firebase iOS SDK auto-discovers it at `FirebaseApp.configure()`
  # via the main bundle. Without it, Firebase init fails with
  # "The default Firebase app has not yet been configured."
  plist_path = File.expand_path('App/GoogleService-Info.plist', __dir__)
  if File.exist?(plist_path)
    already_bundled = app_target.resources_build_phase.files_references.any? do |ref|
      ref.real_path.to_s == plist_path
    end
    unless already_bundled
      app_group = project.main_group.find_subpath('App', false) || project.main_group
      file_ref = app_group.new_reference(plist_path)
      app_target.add_resources([file_ref])
    end
  else
    warn "post_install: GoogleService-Info.plist not found at #{plist_path}; Firebase will fail to init"
  end

  project.save
end
